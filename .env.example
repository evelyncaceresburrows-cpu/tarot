# =====================================================================
# Tarot Ade · variables de entorno
#
# Copia este archivo a .env (local) y configura las mismas variables
# en Vercel (Project Settings → Environment Variables) para Production,
# Preview y Development.
#
# Las variables con prefijo VITE_ se exponen al bundle del frontend.
# No pongas secrets server-side acá.
# =====================================================================

# URL del proyecto Supabase. Settings → API → Project URL
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co

# Anon public key. Settings → API → anon public.
# Es seguro exponerla al cliente — el control de acceso lo hace RLS.
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxx
